{
  "framework": "AMCAF v1.0",
  "description": "Technology-neutral regulatory control taxonomy for multi-cloud financial services compliance",
  "regulatory_sources": [
    "DORA", "FCA PS21/3", "UK GDPR", "ISO/IEC 27001", "NIST CSF",
    "CSSF Circular 22/806", "NDPR", "MAS TRM", "PCI DSS v4.0", "SOC 2 Type II"
