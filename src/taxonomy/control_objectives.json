        "CSSF 22/806 §3.2", "MAS TRM 6.1", "PCI DSS v4.0 Req 7", "SOC 2 CC6.3"
      ],
      "implemented": true,
      "providers": ["AWS", "Azure", "GCP"]
    },
    {
      "control_id": "IAM-02",
      "domain": "Identity & Access Management",
      "objective": "MFA enforced for all administrative access",
